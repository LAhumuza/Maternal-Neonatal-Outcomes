#-------------------------IMPUTATION-FINAL------------------------------------------
data_imputed<- thesis_data
data_imputed <- data_imputed %>%
  mutate(across(where(is.character), as.factor))

meth <- make.method(data_imputed)
pred <- make.predictorMatrix(data_imputed)
meth[c("patid",
       "practiceCode",
       "year",
       "reasonForReferral",
       "postnatalReferralDueToBaby", "delivery")] <- "" #prevent from being imputed
pred[c("patid", "practiceCode", "year", "reasonForReferral", "postnatalReferralDueToBaby", "delivery"), ] <- 0

impt <- mice(
  data_imputed,
  m = 5,
  maxit = 10,
  method = meth,
  predictorMatrix = pred,
  seed = 123
)
saveRDS(impt, "Final_thesis.rds")
View(complete(impt, 1))
