#perineum is recorded as perineal trauma now in all categories
thesis_data <- thesis_data %>% mutate(
  perineum = case_when(
    perineum %in% c("labial_or_minor_tears", "vaginal_wall_tear", "1stDegreeTear") ~ "minor",
    perineum %in% c("2ndDegreeTear", "episiotomy") ~ "moderate",
    perineum %in% c("3rdDegreeTear", "4thDegreeTear") ~ "severe",
    perineum %in% c("intact", "c_section")  ~ "intact",
    TRUE ~ perineum
  ),
  birthingResponsibility = case_when(
    birthingResponsibility %in% c("Obstetrician", "obstetrician") ~ "obstetrician",
    TRUE ~ birthingResponsibility
  ),
  bloodLoss = case_when(
    bloodLoss %in% c("500-1000ml", ">1000ml") ~ ">500ml",
    TRUE ~ bloodLoss
  ),
  bathBirth = case_when(
    bathBirth %in% c("yes", "partial_bath_birth") ~"yes",
    TRUE ~ bathBirth
  ),
  sectionInAnamnesis = case_when(
    sectionInAnamnesis == "ja" ~ "yes",
    TRUE ~ sectionInAnamnesis
  ),
  babyPosition = case_when(
    babyPosition %in% c("backOfHeadFirst", "backOfHeadBehind", "occipitalPosition", "crownPosition",
                        "cephalic") ~ "cephalic",
    babyPosition %in% c("headTransversal", "transversal", "breech", "foreheadFirst",
                        "facePresentation", "asynclitism", "tail") ~ "noncephalic",
    babyPosition == "NULL" ~ NA_character_,
    TRUE ~ babyPosition
    
  ),
  relationship = case_when(
    relationship %in% c("married", "cohabitation", "other relationship") ~ "relation",
    relationship %in% c("single", "widowed") ~ "single",
    relationship == "NULL" ~ NA_character_,
    TRUE ~ relationship
  ),
  
  fetalSurveillance = case_when(
    fetalSurveillance %in% c("STAN", "continuous") ~ "continuous",
    TRUE ~ fetalSurveillance
  ),
  
  pregnancyOnset = case_when(
    pregnancyOnset %in% c("KID", "KI", "intraUterineInsemination") ~ "KI",
    TRUE ~ pregnancyOnset 
  ),
  
  practiceCode = case_when(
    practiceCode =="NULL" ~ NA_character_,
    TRUE ~ practiceCode
  ),
  abortion = case_when(
    abortion == "NULL" ~ NA_character_,
    TRUE ~ abortion
    
  )
  )




